# Telegram bot token from @BotFather (/newbot)
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram chat id (message your bot once, then check
# https://api.telegram.org/bot<TOKEN>/getUpdates -> result[0].message.chat.id)
TELEGRAM_CHAT_ID=

# OPTIONAL, multi-user mode: JSON array of users; when set, TELEGRAM_CHAT_ID and
# GITHUB_REPO above are ignored.
# USERS=[{"chatId":"111","repo":"you/your-training","name":"You"},{"chatId":"222","repo":"you/partner-training","name":"Partner"}]

# DeepSeek API key from https://platform.deepseek.com
DEEPSEEK_API_KEY=

# GitHub fine-grained personal access token, scoped to ONLY your data repo,
# with Contents: Read and write. https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=

# Your data repo (owner/name) — where logs, program, and plans are stored
GITHUB_REPO=

# Any long random string; Telegram echoes it on every webhook call so the app
# can reject forged requests. Generate with: openssl rand -hex 24
WEBHOOK_SECRET=
